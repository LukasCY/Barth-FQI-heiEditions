    <body>

      <!-- =========================================================
           (1) PRIMÄRE AKTEURE
           ========================================================= -->
      <listPerson type="primary">

        <!-- Karl Barth -->
        <person xml:id="barth" role="author">
          <persName xml:lang="de" ana="hc:PreferredAppellation">
            <forename>Karl</forename>
            <surname>Barth</surname>
          </persName>
          <birth when="1886-05-10">
            <placeName>Basel</placeName>
          </birth>
          <death when="1968-12-10">
            <placeName>Basel</placeName>
          </death>
          <occupation>Reformierter Theologe</occupation>
          <affiliation from="1921" to="1930">Professor in
            Göttingen / Münster / Bonn</affiliation>
          <affiliation from="1935" to="1962">Professor in Basel</affiliation>
          <note>Autor von Fides quaerens intellectum (1931).
            Die Anselm-Monographie markiert den Übergang von
            der dialektischen zur kirchlich-dogmatischen Phase
            seines Denkens; sie ist die methodologische
            Selbstverständigung im Vorfeld der Kirchlichen
            Dogmatik (KD I/1, 1932).</note>
          <idno type="GND" ana="hc:GNDURI">118506838</idno>
          <idno type="VIAF">71390726</idno>
          <idno type="Wikidata">Q57317</idno>
        </person>

        <!-- Anselm von Canterbury -->
        <person xml:id="anselm" role="subject">
          <persName xml:lang="la" ana="hc:AlternativeAppellation">
            <forename>Anselmus</forename>
            <addName type="epithet">Cantuariensis</addName>
          </persName>
          <persName xml:lang="de" ana="hc:PreferredAppellation">
            <forename>Anselm</forename>
            <addName type="origin">von Canterbury</addName>
          </persName>
          <persName xml:lang="de" type="alt" ana="hc:AlternativeAppellation">
            <forename>Anselm</forename>
            <addName type="origin">von Aosta</addName>
            <note>Älterer Beiname nach dem Geburtsort.</note>
          </persName>
          <birth notBefore="1033" notAfter="1034">
            <placeName>Aosta</placeName>
          </birth>
          <death when="1109-04-21">
            <placeName>Canterbury</placeName>
          </death>
          <occupation>Benediktinermönch, Abt von Bec
            (1078–1093), Erzbischof von Canterbury
            (1093–1109)</occupation>
          <note>Hauptgegenstand des edierten Werks. Verfasser
            u. a. von Monologion (1076), Proslogion (1077/78,
            in dem das von Barth analysierte "Argument" steht),
            Cur Deus homo (1098), De veritate, De casu diaboli,
            Epistola de incarnatione Verbi, Briefen.
            Heiliggesprochen 1494; Kirchenlehrer seit 1720.</note>
          <idno type="GND" ana="hc:GNDURI">118503065</idno>
          <idno type="VIAF">100184350</idno>
          <idno type="Wikidata">Q43689</idno>
        </person>

        <!-- Gaunilo von Marmoutiers -->
        <person xml:id="gaunilo" role="subject">
          <persName xml:lang="la" ana="hc:AlternativeAppellation">
            <forename>Gaunilo</forename>
            <addName type="origin">Maioris Monasterii</addName>
          </persName>
          <persName xml:lang="de" ana="hc:PreferredAppellation">
            <forename>Gaunilo</forename>
            <addName type="origin">von Marmoutiers</addName>
          </persName>
          <birth notBefore="0994"/>
          <death notAfter="1083"/>
          <occupation>Benediktinermönch im Kloster
            Marmoutiers</occupation>
          <note>Verfaßte den "Liber pro insipiente" gegen den
            Beweisgang des Proslogion 2–4; Anselms Antwort
            ("Responsio editoris" / "Quid ad haec respondeat …")
            ist seither textgeschichtlich mit dem Proslogion
            verbunden. Wird bei Barth in den späteren Kapiteln
            (§ 5–7) behandelt; in § 1.1 nicht erwähnt.</note>
          <idno type="GND" ana="hc:GNDURI">118689886</idno>
          <idno type="VIAF">26931321</idno>
          <idno type="Wikidata">Q1411925</idno>
        </person>

      </listPerson>

