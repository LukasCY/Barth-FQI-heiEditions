        </bibl>

        <!-- Holmes 2017 (Interoperability vs. Interchange) -->
        <bibl xml:id="holmes-2017" type="article">
          <author>Martin Holmes</author>
          <title type="full" ana="hc:PreferredAppellation">Whatever happened to
            interchange?</title>
          <title type="hostJournal" ana="hc:AlternativeTitle">Digital Scholarship in the
            Humanities</title>
          <biblScope unit="vol">32</biblScope>
          <biblScope unit="issue">suppl. 1</biblScope>
          <biblScope unit="page" from="i63" to="i68">i63–i68</biblScope>
          <date when="2017">2017</date>
          <idno type="DOI">10.1093/llc/fqx034</idno>
          <note>Methodologische Referenz für den FAIR-/
            Interchange-Abschnitt der README.</note>
        </bibl>

      </listBibl>

    </body>
