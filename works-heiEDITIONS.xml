        </bibl>

        <!-- Šimek 2022 (Methodologie der Edition) -->
        <bibl xml:id="simek-2022" type="article">
          <author>Jakub Šimek</author>
          <title type="full" ana="hc:PreferredAppellation">heiEDITIONS — eine Heidelberger
